SCOUT_CACHE_DIR=~/.cache/scout-router
SCOUT_DETECTOR_MANIFEST=~/.cache/scout-router/detectors/manifest.json
HF_TOKEN=

D6_PROVIDER=openai
D6_MODEL=gpt-4o
OPENAI_API_KEY=

# OpenAI-compatible endpoint example:
# D6_PROVIDER=openai_compatible
# D6_BASE_URL=https://openrouter.ai/api/v1
# D6_API_KEY=
# D6_MODEL=openai/gpt-4o
#
# OpenRouter shorthand is also accepted:
# OPENROUTER_API_KEY=

# Default uses the published SCOUT predictor through vLLM.
# Use heuristic only for local smoke tests without model assets.
SCOUT_PREDICTOR_BACKEND=vllm
SCOUT_PREDICTOR_TEMPERATURE=0.2
SCOUT_PREDICTOR_TOP_P=0.8
SCOUT_PREDICTOR_TOP_K=20
SCOUT_PREDICTOR_PRESENCE_PENALTY=1.5
SCOUT_PREDICTOR_MAX_TOKENS=4096
SCOUT_PREDICTOR_N_SAMPLES=1
SCOUT_PREDICTOR_SEED=0

SCOUT_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
SCOUT_RETRIEVAL_TOP_K=10
SCOUT_RETRIEVAL_TOP_K_USE=5
